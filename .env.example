# ============================================================
# BizPilot NG — Environment Configuration
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# ============================================================

# --- App ---
APP_NAME=BizPilot NG
APP_ENV=development          # development | production
APP_PORT=8000
APP_HOST=0.0.0.0
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=true

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
TELEGRAM_WEBHOOK_SECRET=your-random-webhook-secret-string
# Set this to your public domain in production (Railway/Render URL)
WEBHOOK_BASE_URL=https://your-app.railway.app

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=2000

# --- OpenAI (Whisper for voice transcription) ---
OPENAI_API_KEY=your-openai-api-key

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- Paystack ---
PAYSTACK_SECRET_KEY=sk_live_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_live_your-paystack-public-key
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-ip-whitelist-hash

# Paystack Plan Codes (create these in Paystack dashboard first)
PAYSTACK_PRO_PLAN_CODE=PLN_xxxxxxxxxx
PAYSTACK_COMMANDER_PLAN_CODE=PLN_xxxxxxxxxx

# --- Redis (optional — for session caching) ---
REDIS_URL=redis://localhost:6379/0

# --- Email (Resend) ---
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@bizpilot.ng
EMAIL_FROM_NAME=BizPilot NG

# --- Storage ---
SUPABASE_BUCKET_NAME=bizpilot-documents

# --- Subscription Limits ---
FREE_MONTHLY_LIMIT=5
PRO_MONTHLY_LIMIT=999999
COMMANDER_MONTHLY_LIMIT=999999

# --- Pricing (in Kobo — 100 kobo = ₦1) ---
PRO_PRICE_KOBO=499900
COMMANDER_PRICE_KOBO=1299900
